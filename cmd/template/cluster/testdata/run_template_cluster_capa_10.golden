---
apiVersion: v1
data:
  values: |
    global:
      connectivity:
        availabilityZoneUsageLimit: 1
        network:
          vpcCidr: 10.85.0.0/24
        subnets:
        - cidrBlocks:
          - availabilityZone: a
            cidr: 10.85.0.128/25
          isPublic: false
        - cidrBlocks:
          - availabilityZone: a
            cidr: 10.85.0.0/26
          isPublic: true
        topology: {}
      controlPlane:
        instanceType: control-plane-instance-type
      metadata:
        description: small single-AZ VPC layout
        name: test11
        organization: test
        preventDeletion: false
      nodePools:
        worker1:
          availabilityZones:
          - eu-west-1a
          customNodeLabels:
          - label=value
          instanceType: big-one
          maxSize: 5
          minSize: 2
          rootVolumeSizeGB: 200
      providerSpecific:
        awsClusterRoleIdentityName: default
        region: the-region
      release:
        version: 25.0.0
kind: ConfigMap
metadata:
  labels:
    giantswarm.io/cluster: test11
  name: test11-userconfig
  namespace: org-test
---
apiVersion: application.giantswarm.io/v1alpha1
kind: App
metadata:
  labels:
    app-operator.giantswarm.io/version: 0.0.0
  name: test11
  namespace: org-test
spec:
  catalog: the-catalog
  config:
    configMap:
      name: ""
      namespace: ""
    secret:
      name: ""
      namespace: ""
  kubeConfig:
    context:
      name: ""
    inCluster: true
    secret:
      name: ""
      namespace: ""
  name: cluster-aws
  namespace: org-test
  userConfig:
    configMap:
      name: test11-userconfig
      namespace: org-test
  version: ""
